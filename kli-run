#!/usr/bin/env bash
# kli-run - Interactive Experience Wizard

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
source "$SCRIPT_DIR/kli-ui" || exit 1
VERSION=$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null || echo "0.1.0")

spinner() {
    local pid=$!
    local delay=0.1
    local spinstr='|/-\'
    while [ "$(ps a | awk '{print $1}' | grep $pid)" ]; do
        local temp=${spinstr#?}
        printf "  ${D}[%c]${NC}  $1" "$spinstr"
        local spinstr=$temp${spinstr%"$temp"}
        sleep $delay
        printf "\r"
    done
    printf "  ${G}${ICON_OK}${NC}  $1\n"
}

clear
draw_logo "$VERSION"
draw_status_bar "run wizard"

# 1. Vérification connexion
echo -e "${B}Initialising session...${NC}"
(sleep 1) & spinner "Connecting to Kubernetes cluster..."

if ! kubectl cluster-info --request-timeout=2s &>/dev/null; then
    echo -e "\n  ${R}${ICON_ERR}${NC}  ${B}Connection Failed${NC}"
    echo -e "     ${D}KLI needs an active context to function properly.${NC}"
    exit 1
fi

CURRENT_CTX=$(kubectl config current-context)
echo -e "     ${D}Context:${NC} ${CY}$CURRENT_CTX${NC}\n"

# 2. Concept
echo -e "${B}How it works${NC}"
draw_line "How it works"
echo -e "  ${G}${ICON_ARROW}${NC} ${B}SMART NAVIGATION${NC} ${D}› Choose Namespace › Action › Resource${NC}"
echo -e "  ${G}${ICON_ARROW}${NC} ${B}LIVE PREVIEW${NC}     ${D}› See YAML or Logs in real-time${NC}"
echo -e "  ${G}${ICON_ARROW}${NC} ${B}KEYBOARD FIRST${NC}   ${D}› ‹ENTER› Select  •  ‹ESC› Back${NC}\n"

# 3. Analyse
echo -e "${B}Cluster Discovery${NC}"
(sleep 0.8) & spinner "Scanning resources..."

NS_COUNT=$(kubectl get namespaces --no-headers 2>/dev/null | wc -l | tr -d ' ')
POD_COUNT=$(kubectl get pods --all-namespaces --no-headers 2>/dev/null | wc -l | tr -d ' ')

echo -e "  ${ICON_PREFIX} ${D}Namespaces detected :${NC} ${B}$NS_COUNT${NC}"
echo -e "  ${ICON_PREFIX} ${D}Total Pods running  :${NC} ${B}$POD_COUNT${NC}\n"

# 4. Transition vers l'Explorer
draw_line "──────────────────────────────────────────"
echo -e "  ${B}Ready to start explorer?${NC} ${D}(Press any key)${NC}"
read -n 1 -s
echo -e "\n  ${G}${ICON_ARROW}${NC} Launching KLI Explorer mode..."
sleep 0.5

# Lancement propre avec le flag --explorer pour éviter la boucle HOME
if [[ -f "$SCRIPT_DIR/kli" ]]; then
    exec "$SCRIPT_DIR/kli" --explorer
else
    exec kli --explorer
fi
