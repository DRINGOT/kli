#!/usr/bin/env bash
# kli-ns - Namespace Switcher (High Performance)

SCRIPT_DIR="$(dirname "$(readlink -f "$0")")"
source "$SCRIPT_DIR/kli-ui" || exit 1

# --- MODE PREVIEW INTERNE ---
if [[ "${1:-}" == "--preview" ]]; then
    ns="$2"
    echo -e "${CY}${ICON_PREFIX} NAMESPACE: ${B}$ns${NC}"
    draw_line "NAMESPACE: $ns"

    # 1. PODS STATUS (Alignement dynamique)
    echo -e "\n${BL}⬡ PODS${NC}"
    # On limite à 15 pods pour garder la preview rapide
    pods=$(kubectl get pods -n "$ns" --no-headers --request-timeout=1.5s 2>/dev/null | head -n 15)

    if [[ -z "$pods" ]]; then
        echo -e "   ${D}No pods found or unreachable${NC}"
    else
        printf "   ${D}%-45s %-10s %-15s %-5s${NC}\n" "NAME" "READY" "STATUS" "AGE"
        echo "$pods" | while read -r name ready status restarts age; do
            printf "   %-45s %-10s " "${name:0:43}" "$ready"
            # Utilisation de smart_color pour les Running/Error/Pending
            echo "$status" | smart_color | tr -d '\n'
            printf " %-5s\n" "${D}$age${NC}"
        done
    fi

    # 2. INGRESS & ROUTES
    echo -e "\n${CY}⎆ INGRESS${NC}"
    ingress=$(kubectl get ingress -n "$ns" --no-headers --request-timeout=1.5s \
        -o custom-columns="N:.metadata.name,A:.status.loadBalancer.ingress[0].ip,H:.spec.rules[*].host" 2>/dev/null)

    if [[ -z "$ingress" ]]; then
        echo -e "   ${D}No ingress found${NC}"
    else
        printf "   ${D}%-45s %-20s %-s${NC}\n" "NAME" "ADDRESS" "HOST"
        echo "$ingress" | while read -r name ip hosts; do
            # On affiche le premier host si multiple
            h=$(echo "$hosts" | cut -d',' -f1)
            printf "   %-45s %-20s %s\n" "${name:0:43}" "${ip:-${D}pending${NC}}" "${CY}${h:0:40}${NC}"
        done
    fi

    # 3. RESOURCE USAGE (TOP)
    echo -e "\n${Y}⚡ TOP PODS (MEM)${NC}"
    # On trie par mémoire (colonne 3) pour voir les plus gourmands
    top_pods=$(kubectl top pods -n "$ns" --no-headers --request-timeout=2s 2>/dev/null | sort -rhk 3 | head -n 8)

    if [[ -n "$top_pods" ]]; then
        printf "   ${D}%-45s %-15s %-15s${NC}\n" "NAME" "CPU" "MEMORY"
        echo "$top_pods" | while read -r name cpu mem; do
            printf "   %-45s %-15s %-15s\n" "${name:0:43}" "$cpu" "$mem"
        done | smart_color
    else
        echo -e "   ${D}Metrics not available${NC}"
    fi

    exit 0
fi

# --- INTERFACE PRINCIPALE ---
current_ns=$(kubectl config view --minify -o jsonpath='{..namespace}' 2>/dev/null || echo "default")

# Liste des namespaces sans boule, mais avec une mise en avant de l'actuel
list_namespaces() {
    kubectl get ns -o name | sed 's/namespace\///' | while read -r line; do
        if [[ "$line" == "$current_ns" ]]; then
            echo -e "${B}${G}$line (current)${NC}"
        else
            echo -e "$line"
        fi
    done
}

# fzf avec ton style centralisé
choice=$(list_namespaces | fzf "${FZF_UI_OPTS[@]}" $FZF_COLOR_OPTS \
    --ansi \
    --style=full --padding=1,2 \
    --header-label=" KLI : NAMESPACE SWITCH " \
    --input-label=" NAMESPACE SELECTION " \
    --border-label-pos=bottom --border-label=" $FOOTER_LABEL " \
    --preview "bash $0 --preview \$(echo {} | sed 's/ (current)//;s/  //')" \
    $FZF_PREVIEW_OPTS \
    --prompt "Switch to › ")

if [[ -n "$choice" ]]; then
    # Nettoyage du nom sélectionné
    clean_ns=$(echo "$choice" | sed 's/ (current)//;s/  //' | xargs)

    kubectl config set-context --current --namespace="$clean_ns" >/dev/null
    echo -e "\n${G}${ICON_OK}${NC} Switched to namespace: ${B}$clean_ns${NC}"
fi
